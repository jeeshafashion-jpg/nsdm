<p style="font-size:25px" class="has-background has-tan-background-color">To drive quantity, quality and reach of training provision and outcomes. </p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To provide horizontal and vertical pathways to academic qualifications and the  job market, respectively.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To improve overall quality of instruction at training institutions across the country. </p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To meet trainer’s training requirement in each sector and geographical region across India. </p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To ensure adequate availability of trainers in the skills space. </p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To provide trainers with long-term career progression pathways</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To ensure that youth in India are trained at the highest global standards, in order to enable them to access employment opportunities abroad.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To provide information about employment opportunities abroad and enable aspirants to access them.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"backgroundColor":"tan","customFontSize":25} -->
<p style="font-size:25px" class="has-background has-tan-background-color">To ensure international mobility of skilled workers in the country</p>
<!-- /wp:paragraph -->]]></content:encoded>
