msgstr "Leite Besucher von gelöschten URLs zum ursprünglichen Beitrag weiter."

#: includes/class-ddp-admin.php:511
msgid "Compare by meta:"
msgstr "Vergleich nach Metadaten:"

#: includes/class-ddp-admin.php:511 includes/class-ddp-admin.php:803
